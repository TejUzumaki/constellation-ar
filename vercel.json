{
  "version": 2,
  "name": "constellation-ar",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), geolocation=(self), gyroscope=(self), accelerometer=(self), magnetometer=(self)"
        }
      ]
    }
  ]
}
